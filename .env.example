# Google Sheet (ID déjà défini par défaut dans le code)
GOOGLE_SHEET_ID=1XUfrF_-325vQlPFHVtShphZZEPDKLKc82KAXo9B7Zuo
GOOGLE_SHEET_RANGE=A:J

# Option A — Compte de service Google (recommandé sur Vercel)
# 1. Google Cloud Console > créer un compte de service
# 2. Activer l'API Google Sheets
# 3. Télécharger la clé JSON
# 4. Partager le Google Sheet avec l'email du compte de service (Éditeur)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Option B — Apps Script (plus simple, sans compte de service)
# Colle scripts/google-sheet-webhook.gs dans Extensions > Apps Script
# Déploie en "Application Web" (accès : Tout le monde) puis colle l'URL ici :
GOOGLE_APPS_SCRIPT_URL=

# Calendly après candidature
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/teocomyn
